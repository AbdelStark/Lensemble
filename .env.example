# Local demo secrets and URLs. Copy to `.env` or export in your shell.
# `.env` is ignored by git; never commit real Mollie API keys.

# Mollie test-mode key. Required only for the credentialed Mollie smoke path.
MOLLIE_API_KEY=test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public base URL used in Mollie redirect/webhook examples during hosted demos.
# For local-only mock mode, this may stay at localhost.
LENSEMBLE_PUBLIC_BASE_URL=http://127.0.0.1:8765

# Sovereign-economy demo defaults. These are simulation values, not legal terms.
LENSEMBLE_DEMO_SALE_AMOUNT_EUR=1000000.00
LENSEMBLE_DEMO_ORCHESTRATOR_SHARE=0.20
